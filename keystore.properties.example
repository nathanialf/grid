# Release signing credentials.
#
# Copy this file to `keystore.properties` (same directory, the repo root) and fill in
# the real values once you've copied your release keystore onto this machine.
#
#   cp keystore.properties.example keystore.properties
#
# keystore.properties is gitignored and must NEVER be committed — it contains passwords.
# As long as keystore.properties is absent, release builds are produced UNSIGNED.

# Absolute path to the keystore file. An absolute path is recommended to avoid
# confusion about what it's relative to. Example:
#   storeFile=/primary/home/n/keys/grid-release.jks
storeFile=/absolute/path/to/your-release-key.jks

# Password for the keystore file itself.
storePassword=CHANGE_ME

# The alias of the key inside the keystore that was used for the original release.
keyAlias=CHANGE_ME

# Password for that specific key (often the same as storePassword).
keyPassword=CHANGE_ME
